{
  "name": "pba-ministerio-abierto",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:changed": "bash -lc 'FILES=$(git diff --name-only --diff-filter=ACMRTUXB HEAD | rg \"\\.(js|cjs|mjs|ts|tsx|vue)$\" || true); if [ -z \"$FILES\" ]; then echo \"No hay archivos JS/TS/Vue cambiados para lint\"; exit 0; fi; eslint $FILES'",
    "typecheck": "nuxt typecheck",
    "icons:optimize": "svgo --config=svgo.config.js --multipass --recursive --folder app/assets/icons",
    "icons:optimize:pba": "svgo --config=svgo.config.js --multipass --folder app/assets/icons/pba",
    "icons:optimize:der": "svgo --config=svgo.config.js --multipass --folder app/assets/icons/der",
    "verify": "pnpm typecheck && pnpm lint && pnpm build",
    "verify:changed": "pnpm typecheck && pnpm lint:changed && pnpm build",
    "db:generate": "prisma generate",
    "db:migrate": "DATABASE_URL=${DATABASE_MIGRATION_URL:-$DATABASE_URL} prisma migrate dev",
    "db:deploy": "DATABASE_URL=${DATABASE_MIGRATION_URL:-$DATABASE_URL} prisma migrate deploy",
    "db:deploy:remote": "bash scripts/deploy-db.sh",
    "db:seed": "prisma db seed",
    "db:seed:base": "prisma db seed -- --profile base",
    "db:seed:institution": "prisma db seed -- --profile institution",
    "db:seed:demo": "prisma db seed -- --profile demo",
    "db:seed:all": "prisma db seed -- --profile base,institution,demo",
    "db:studio": "prisma studio",
    "db:test": "tsx scripts/test-database.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db:setup": "tsx scripts/setup-test-db.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1093.0",
    "@aws-sdk/s3-request-presigner": "^3.1093.0",
    "@iconify-json/lucide": "^1.2.118",
    "@internationalized/date": "^3.12.2",
    "@nuxt/ui": "^4.10.0",
    "@prisma/adapter-mariadb": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "isomorphic-dompurify": "^3.19.0",
    "marked": "^18.0.7",
    "mrmime": "^2.0.1",
    "nodemailer": "^9.0.3",
    "nunjucks": "^3.2.4",
    "nuxt": "^4.5.0",
    "nuxt-auth-utils": "0.5.29",
    "tailwindcss": "^4.3.3",
    "vue-advanced-cropper": "^2.8.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@adonisjs/hash": "9.1.1",
    "@faker-js/faker": "^10.5.0",
    "@iconify-json/simple-icons": "^1.2.91",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "^4.0.3",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/nunjucks": "^3.2.6",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.7.0",
    "happy-dom": "^20.11.1",
    "playwright-core": "^1.61.1",
    "prisma": "^7.9.0",
    "svgo": "^4.0.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.8"
  },
  "packageManager": "pnpm@11.5.0"
}
