# Configuración para scripts/deploy-db.sh (aplicar migraciones a una DB remota).
# Copiá este archivo a `.env.deploy` (gitignoreado) y completá los valores.

# URL de la app apuntando al TÚNEL LOCAL. El puerto (aquí 3307) define el
# puerto local que abre el túnel SSH hacia la DB del droplet. El usuario y la
# base deben existir ya en el servidor (creados con un usuario con privilegios).
DATABASE_URL=mysql://app:CAMBIAR_PASSWORD@127.0.0.1:3307/consultas_prod

# Alias/host SSH del droplet de MySQL (el que usás con `ssh do-mysql`).
SSH_HOST=do-mysql

# Destino de la DB visto DESDE el droplet. MySQL local en el droplet: 127.0.0.1:3306.
# REMOTE_DB=127.0.0.1:3306

# Perfiles de seed por defecto al usar --seed (coma-separados).
# SEED_PROFILES=base
