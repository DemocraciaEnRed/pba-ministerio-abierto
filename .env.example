NUXT_SESSION_PASSWORD=password-with-at-least-32-characters

# Secreto para el endpoint oculto de alta de administradores
# (POST /api/_internal/admin-bootstrap). Dejalo vacío para deshabilitarlo
# (responde 404). Usá un string largo y aleatorio en staging/producción.
NUXT_ADMIN_BOOTSTRAP_SECRET=

# Database (Docker Compose / MariaDB)
DB_ROOT_PASSWORD=changeme-root-password
DB_NAME=consultas_ciudadanas
DB_USER=consultas_app
DB_PASSWORD=changeme-app-password

# For local tooling running on the host (Prisma, Nuxt dev server, scripts)
DATABASE_URL=mysql://consultas_app:changeme-app-password@127.0.0.1:3306/consultas_ciudadanas

# Prisma migrate dev needs permission to create shadow databases in MySQL/MariaDB.
DATABASE_MIGRATION_URL=mysql://root:changeme-root-password@127.0.0.1:3306/consultas_ciudadanas

# If the app runs inside the same Docker network as MariaDB, use:
# DATABASE_URL=mysql://consultas_app:changeme-app-password@mariadb:3306/consultas_ciudadanas

# --- App ---
# URL pública base, usada para construir links en emails.
NUXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email (SMTP) ---
# Dejá NUXT_MAIL_TRANSPORT vacío (o distinto de 'smtp') para modo dev:
# los emails NO se envían, se loguean a consola.
NUXT_MAIL_TRANSPORT=
NUXT_MAIL_HOST=
NUXT_MAIL_PORT=587
NUXT_MAIL_SECURE=false
NUXT_MAIL_USER=
NUXT_MAIL_PASSWORD=
NUXT_MAIL_FROM=Consultas Ciudadanas <no-reply@example.com>

# --- Storage de archivos ---
# 'local' guarda en disco; 's3' usa S3 / DigitalOcean Spaces.
NUXT_STORAGE_DRIVER=local
NUXT_STORAGE_LOCAL_DIR=./.data/uploads

# Solo para NUXT_STORAGE_DRIVER=s3 (ejemplo DigitalOcean Spaces):
NUXT_STORAGE_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
NUXT_STORAGE_S3_REGION=us-east-1
NUXT_STORAGE_S3_ACCESS_KEY_ID=
NUXT_STORAGE_S3_SECRET_ACCESS_KEY=
NUXT_STORAGE_S3_BUCKET=
# Prefijo base opcional dentro del bucket. Ej: projects/consultas-ciudadanas-dev
NUXT_STORAGE_S3_PREFIX=
# Base URL pública (CDN o endpoint del bucket). Si se deja vacía, se usan URLs presignadas.
NUXT_STORAGE_S3_PUBLIC_BASE_URL=
# Conveniente dejar en false para DigitalOcean Spaces, que no soporta virtual-hosted-style URLs.
NUXT_STORAGE_S3_FORCE_PATH_STYLE=false
