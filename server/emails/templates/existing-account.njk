{% extends "layout.njk" %}

{% block title %}Ya tenés una cuenta{% endblock %}

{% block content %}
  <h1 style="margin:0 0 16px; font-size:20px; color:#18181b;">¡Hola!</h1>
  <p style="margin:0 0 16px;">
    Recibimos un intento de registro con esta dirección de correo, pero ya existe
    una cuenta asociada. No es necesario crear una nueva.
  </p>
  <p style="margin:0 0 24px;">
    <a href="{{ loginUrl }}"
       style="display:inline-block; background-color:#18181b; color:#ffffff; text-decoration:none; padding:12px 24px; border-radius:8px; font-weight:600;">
      Iniciar sesión
    </a>
  </p>
  <p style="margin:0; color:#71717a; font-size:13px;">
    Si olvidaste tu contraseña, podés
    <a href="{{ recoverUrl }}" style="color:#2563eb;">recuperarla acá</a>.
  </p>
{% endblock %}
