<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ platformName | default("Consultas Ciudadanas") }}{% endblock %}</title>
  </head>
  <body style="margin:0; padding:0; background-color:#f4f4f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f5; padding:24px 0;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:480px; background-color:#ffffff; border-radius:12px; overflow:hidden; border:1px solid #e4e4e7;">
            <tr>
              <td style="padding:24px 32px; border-bottom:1px solid #e4e4e7;">
                <span style="font-size:18px; font-weight:600; color:#18181b;">{{ platformName | default("Consultas Ciudadanas") }}</span>
              </td>
            </tr>
            <tr>
              <td style="padding:32px; color:#3f3f46; font-size:15px; line-height:1.6;">
                {% block content %}{% endblock %}
                {% if institutionName %}
                  <p style="margin:24px 0 0; color:#3f3f46;">Saludos,<br>{{ institutionName }}</p>
                {% endif %}
                {% if contactEmail %}
                  <p style="margin:16px 0 0; color:#71717a; font-size:13px;">
                    Ante cualquier consulta podés escribirnos a
                    <a href="mailto:{{ contactEmail }}" style="color:#2563eb;">{{ contactEmail }}</a>.
                  </p>
                {% endif %}
              </td>
            </tr>
            <tr>
              <td style="padding:20px 32px; border-top:1px solid #e4e4e7; color:#a1a1aa; font-size:12px; line-height:1.5;">
                Este es un mensaje automático, por favor no respondas a este correo.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
